# =============================================================================
# MAGNA CRM — Plantilla de variables de entorno
# Copiar a `.env.local` (dev) o configurar en Vercel/Supabase (prod/staging).
# Nunca commitear `.env*` salvo este `.env.example`.
# =============================================================================

# --- Supabase (Fase 1) ---
# Project URL: https://app.supabase.com/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service Role: SOLO en server (API routes / Edge Functions). Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=
# Si se usa CLI vinculado:
SUPABASE_PROJECT_REF=

# --- Google Workspace OAuth (Fase 2 + Fase 4) ---
# Cloud Console → OAuth 2.0 Client. Restringir a dominio del workspace cliente.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
# Dominio del workspace cliente (login domain restriction):
GOOGLE_WORKSPACE_DOMAIN=

# --- Slack (Fase 4) ---
# Incoming Webhook URL para notificaciones generales:
SLACK_WEBHOOK_URL=
# Bot token (xoxb-...) si se usa app Slack en lugar de solo webhook:
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- Gemini / Google Generative AI (Fase 4) ---
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Modelo por defecto:
GEMINI_MODEL=gemini-2.0-flash

# --- Zapier (Fase 4) ---
# Secret compartido para validar webhooks entrantes en /api/zapier/[event]
ZAPIER_WEBHOOK_SECRET=

# --- Notion (Fase 4 - P2) ---
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- Observabilidad (Fase 5) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Aplicación ---
# URL pública (usar la de Vercel en prod):
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Entorno: development | staging | production
NEXT_PUBLIC_APP_ENV=development
